{
  "name": "@gaforov/selenium-mcp",
  "version": "0.2.1",
  "description": "Selenium MCP server for AI agents — 39 browser automation tools: navigation, clicks, typing, assertions, screenshots, multi-session, page snapshots with stable element refs, selector hints, and batched execution.",
  "mcpName": "io.github.gaforov/selenium-mcp",
  "main": "dist/server.js",
  "bin": {
    "selenium-mcp": "dist/server.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CHANGELOG.md",
    "docs/ARCHITECTURE.md",
    "docs/CLIENT_INTEGRATION.md",
    "docs/DEVELOPMENT.md",
    "docs/README.md",
    "docs/TOOL_REFERENCE.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('node:fs').chmodSync('dist/server.js', 0o755)\"",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "test": "npm run build && node --test test/*.test.mjs",
    "prepack": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "selenium",
    "selenium-webdriver",
    "webdriver",
    "browser-automation",
    "browser",
    "automation",
    "testing",
    "test-automation",
    "web-testing",
    "e2e",
    "ai",
    "ai-agents",
    "agent",
    "llm",
    "claude",
    "claude-desktop",
    "cursor",
    "copilot",
    "windsurf",
    "goose",
    "screenshot",
    "web-scraping",
    "playwright-alternative"
  ],
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gaforov/selenium-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/gaforov/selenium-mcp/issues"
  },
  "homepage": "https://github.com/gaforov/selenium-mcp#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "selenium-webdriver": "^4.46.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.5",
    "@types/selenium-webdriver": "^4.35.6",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}